{
  "name": "poketypes",
  "bsc-flags": ["-bs-super-errors"],
  "sources": [
    {
      "dir": "src",
      "subdirs": true
    }
  ],
  "package-specs": [
    {
      "module": "es6",
      "in-source": true
    }
  ],
  "suffix": ".bs.js",
  "namespace": true,
  "bs-dependencies": ["bs-fetch", "decco"],
  "ppx-flags": ["decco/ppx"],
  "gentypeconfig": {
    "language": "typescript"
  }
}
